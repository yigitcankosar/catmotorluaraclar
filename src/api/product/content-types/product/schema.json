{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "Description": {
      "type": "blocks"
    },
    "Price": {
      "type": "integer"
    },
    "Brand": {
      "type": "enumeration",
      "enum": [
        "Mercedes",
        "BMW",
        "Audi",
        "Range Rover"
      ]
    },
    "Image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "OEM_Code": {
      "type": "string"
    },
    "Category": {
      "type": "enumeration",
      "enum": [
        "Kaporta & Gövde",
        "Aydınlatma Grubu",
        "Elektrik & Elektronik",
        "Motor Parçaları",
        "Fren Sistemi",
        "Süspansiyon"
      ]
    }
  }
}
